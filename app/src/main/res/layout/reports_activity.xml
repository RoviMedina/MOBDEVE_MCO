<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expense Reports"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="center"
            android:text="Pie Chart Placeholder\nExpenses by Category"
            android:textSize="18sp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total This Month\n₱4,250.00"
            android:textSize="20sp"
            android:padding="16dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Highest Category\nFood"
            android:textSize="20sp"
            android:padding="16dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="center"
            android:text="Bar Chart Placeholder\nMonthly Spending"
            android:textSize="18sp"
            android:background="#EEEEEE" />

    </LinearLayout>
</ScrollView>